{
  "name": "clawtributor-status",
  "version": "0.2.6",
  "description": "A macOS and Windows desktop app for GitHub contribution metrics.",
  "private": false,
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron:dev": "concurrently -k \"npm:dev\" \"wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "typecheck": "tsc --noEmit",
    "generate-icons": "scripts/generate-icons.sh",
    "build": "pnpm generate-icons && pnpm build:renderer && electron-builder --publish never",
    "build:mac": "pnpm generate-icons && pnpm build:renderer && electron-builder --mac --publish never",
    "build:mac:native": "pnpm generate-icons && scripts/package-swift-macos.sh",
    "build:win": "pnpm generate-icons && pnpm build:renderer && electron-builder --win --publish never",
    "build:renderer": "tsc && vite build",
    "dist": "npm run build"
  },
  "keywords": [
    "github",
    "contributions",
    "desktop",
    "electron"
  ],
  "author": "Dallin Romney",
  "license": "MIT",
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.romneyda.clawtributorstatus",
    "productName": "Clawtributor Status",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "romneyda",
      "repo": "clawtributor-status"
    }
  }
}
