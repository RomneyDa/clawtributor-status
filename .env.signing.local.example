# Copy this file to .env.signing.local and fill in real values.
# .env.signing.local is gitignored.
#
# Variable names match the GitHub Actions release secrets so the same values
# can be reused locally and in CI (see .github/workflows/release.yml).

# Native Swift macOS signing and notarization.
export DEVELOPER_ID_APPLICATION='Developer ID Application: Your Name (TEAMID)'
export APPLE_ID='you@example.com'
export APPLE_APP_SPECIFIC_PASSWORD='xxxx-xxxx-xxxx-xxxx'
export APPLE_TEAM_ID='TEAMID'

# Electron macOS signing.
# MAC_CSC_LINK can be an absolute path to a .p12, a base64-encoded .p12, or an
# https URL. scripts/build-signed-local.sh maps these to CSC_LINK /
# CSC_KEY_PASSWORD for electron-builder. Use single quotes so $, !, \, and
# backticks in the password are not interpreted by the shell.
export MAC_CSC_LINK='/absolute/path/to/developer-id-application.p12'
export MAC_CSC_KEY_PASSWORD='p12-password'
