# Copy this file to .env.signing.local and fill in real values.
# .env.signing.local is gitignored.

# Native Swift macOS signing and notarization.
export DEVELOPER_ID_APPLICATION="Developer ID Application: Your Name (TEAMID)"
export APPLE_ID="you@example.com"
export APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
export APPLE_TEAM_ID="TEAMID"

# Electron macOS signing.
# For local builds this can be an absolute path to your exported Developer ID
# Application .p12 file. For CI, use GitHub secrets instead.
export CSC_LINK="/absolute/path/to/developer-id-application.p12"
export CSC_KEY_PASSWORD="p12-password"
